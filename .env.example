# Copy to .env and fill in. NEVER commit .env to git.

# Binance Spot Testnet: https://testnet.binance.vision
BINANCE_SPOT_API_KEY=your_spot_testnet_key
BINANCE_SPOT_API_SECRET=your_spot_testnet_secret

# Binance Futures Testnet: https://testnet.binancefuture.com
BINANCE_FUTURES_API_KEY=your_futures_testnet_key
BINANCE_FUTURES_API_SECRET=your_futures_testnet_secret

# Set to "false" to go live. Default true (testnet).
USE_TESTNET=true
